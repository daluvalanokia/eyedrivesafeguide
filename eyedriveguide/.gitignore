# packages.lock.json

# ── ASP.NET / Razor ───────────────────────────────────────────
wwwroot/bundle/
wwwroot/dist/
# Published output
**/publish/

# ── SQLite runtime files (never commit the live DB) ───────────
*.db
*.db-shm
*.db-wal

# ── Secrets / environment (NEVER commit) ─────────────────────
appsettings.Development.json
appsettings.Local.json
*.pfx
*.p12
secrets.json
.env
.env.*

# ── Test results ──────────────────────────────────────────────
TestResults/
*.trx
*.coveragexml
coverage*/

# ── OS noise ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
