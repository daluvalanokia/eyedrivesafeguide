@{
    ViewData["Title"] = "Privacy";
}
<div class="container py-4">
    <h2 class="fw-bold">Privacy Policy</h2>
    <p class="lead">eyedriveguide runs entirely on your device. All data stays local.</p>
    <ul>
        <li>GPS coordinates are processed in real time and are never sent to external servers (unless you configure a routing API key).</li>
        <li>Microphone audio is analysed for decibel levels only — no audio is recorded or transmitted.</li>
        <li>Camera frames are analysed locally for optical-flow backing detection — no images are stored or transmitted.</li>
        <li>Your profile data, addresses, and settings are stored in a local SQLite database on this device.</li>
    </ul>
</div>
