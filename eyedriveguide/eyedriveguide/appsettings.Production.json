{
  "// SECURITY NOTE": "Sensitive values must be set via environment variables or Azure Key Vault. Never commit real values to this file.",

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000",
        "// NOTE": "Redirect to HTTPS handled by UseHttpsRedirection()"
      },
      "Https": {
        "Url": "https://localhost:5001"
      }
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "EyeDriveGuide": "Information"
    }
  },

  "// SECURITY - Keys must come from environment variables": {
    "OpenRouteService__ApiKey": "SET_VIA_ENV_VAR",
    "EDG_DB_ENCRYPT_KEY": "SET_VIA_ENV_VAR (openssl rand -base64 32)",
    "EDG_ALERT_SIGNING_KEY": "SET_VIA_ENV_VAR"
  },

  "DataRetention": {
    "SessionRetentionDays": 90
  },

  "HstsOptions": {
    "MaxAge": 31536000,
    "IncludeSubDomains": true,
    "Preload": false
  },

  "AllowedHosts": "localhost"
}
